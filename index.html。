                password = settings.password || '0000';
                isPasswordProtected = settings.isPasswordProtected !== undefined ? settings.isPasswordProtected : true;
                currentSort = settings.currentSort || 'date-desc';
                sortSelect.value = currentSort;
                
                if (settings.currentTheme && settings.currentTheme !== 'default') {
                    document.body.className = 'theme-' + settings.currentTheme;
                    themeOptions.forEach(opt => {
                        opt.classList.toggle('active', opt.dataset.theme === settings.currentTheme);
                    });
                    currentThemeSpan.textContent = themeNames[settings.currentTheme] || '星空紫';
                    currentThemeSpan.style.background = 'linear-gradient(135deg, var(--primary-color), var(--accent-color))';
                    currentThemeSpan.style.webkitBackgroundClip = 'text';
                    currentThemeSpan.style.webkitTextFillColor = 'transparent';
                }
            }
            
            const savedCategories = localStorage.getItem(STORAGE_KEYS.CATEGORIES);
            if (savedCategories) {
                customCategories = JSON.parse(savedCategories);
                renderCustomCategories();
            }
            
            passwordProtection.checked = isPasswordProtected;
            updateSystemStatus();
        }
        
        async function rebuildWorksWithImages(worksMeta) {
            const rebuiltWorks = [];
            
            for (const meta of worksMeta) {
                if (meta.type === 'image' && !meta.isExternal) {
                    // 云端图片优先
                    if (meta.cloudPath) {
                        const cloudUrl = getCloudFileUrl(meta.cloudPath);
                        if (cloudUrl) {
                            rebuiltWorks.push({
                                ...meta,
                                preview: cloudUrl,
                                fromCloud: true
                            });
                            continue;
                        }
                    }
                    
                    // 本地缓存次之
                    try {
                        const data = await getImageFromIndexedDB(meta.id);
                        if (data && data.blob) {
                            imageBlobCache[meta.id] = URL.createObjectURL(data.blob);
                            rebuiltWorks.push({
                                ...meta,
                                preview: imageBlobCache[meta.id],
                                idbBlob: data.blob
                            });
                        } else {
                            rebuiltWorks.push({
                                ...meta,
                                preview: '',
                                missingImage: true
                            });
                        }
                    } catch (e) {
                        rebuiltWorks.push({
                            ...meta,
                            preview: '',
                            missingImage: true
                        });
                    }
                } else {
                    rebuiltWorks.push(meta);
                }
            }
            
            return rebuiltWorks;
        }
        
        function updateSystemStatus() {
            passwordStatus.textContent = isPasswordProtected ? '已启用' : '已禁用';
            passwordStatus.style.color = isPasswordProtected ? '#10b981' : '#ef4444';
            worksCountSpan.textContent = worksData.length;
        }
        
        function sortWorks(works) {
            const sorted = [...works];
            switch (currentSort) {
                case 'date-desc':
                    sorted.sort((a, b) => new Date(b.date || 0) - new Date(a.date || 0));
                    break;
                case 'date-asc':
                    sorted.sort((a, b) => new Date(a.date || 0) - new Date(b.date || 0));
                    break;
                case 'name-asc':
                    sorted.sort((a, b) => a.title.localeCompare(b.title, 'zh-CN'));
                    break;
                case 'name-desc':
                    sorted.sort((a, b) => b.title.localeCompare(a.title, 'zh-CN'));
                    break;
            }
            return sorted;
        }
        
        function searchWorks(works) {
            if (!searchQuery) return works;
            const query = searchQuery.toLowerCase();
            return works.filter(work => 
                work.title.toLowerCase().includes(query) ||
                work.description.toLowerCase().includes(query) ||
                (subcategoryMap[work.subcategory] || work.subcategory).toLowerCase().includes(query)
            );
        }
        
        function renderCustomCategories() {
            const existingCustom = categoryTags.querySelectorAll('.category-tag.custom');
            existingCustom.forEach(tag => tag.remove());
            
            customCategories.forEach(cat => {
                const tag = document.createElement('span');
                tag.className = 'category-tag custom';
                tag.dataset.category = cat.id;
                tag.innerHTML = `${cat.name} <i class="fas fa-times" style="margin-left: 5px; font-size: 0.8em; opacity: 0.7;" title="删除分类"></i>`;
                
                tag.querySelector('i').addEventListener('click', (e) => {
                    e.stopPropagation();
                    if (confirm(`确定要删除"${cat.name}"分类吗？`)) {
                        customCategories = customCategories.filter(c => c.id !== cat.id);
                        saveToStorage();
                        renderCustomCategories();
                        showToast('分类已删除');
                    }
                });
                
                tag.addEventListener('click', (e) => {
                    if (e.target.tagName !== 'I') {
                        filterByCategory(cat.id);
                    }
                });
                
                categoryTags.insertBefore(tag, addCustomCategoryBtn);
            });
        }
        
        function filterByCategory(category) {
            currentCategory = category;
            
            categoryTags.querySelectorAll('.category-tag').forEach(tag => {
                tag.classList.toggle('active', tag.dataset.category === category);
            });
            
            renderWorks();
        }
        
        function renderWorks() {
            worksGrid.innerHTML = '';
            
            let filteredWorks = currentCategory === 'all' 
                ? [...worksData] 
                : worksData.filter(work => work.category === currentCategory);
            
            filteredWorks = searchWorks(filteredWorks);
            filteredWorks = sortWorks(filteredWorks);
            
            if (filteredWorks.length === 0) {
                emptyState.style.display = 'block';
                if (searchQuery) {
                    emptyState.querySelector('h3').textContent = '未找到匹配的作品';
                    emptyState.querySelector('p').textContent = '请尝试其他搜索关键词 ✨';
                } else {
                    emptyState.querySelector('h3').textContent = '此分类暂无作品';
                    emptyState.querySelector('p').textContent = '点击上方上传区域添加您的第一个作品 ✨';
                }
            } else {
                emptyState.style.display = 'none';
                
                filteredWorks.forEach(work => {
                    const workCard = createWorkCard(work);
                    worksGrid.appendChild(workCard);
                });
            }
        }
        
        function createWorkCard(work) {
            const card = document.createElement('div');
            card.className = 'work-card';
            card.setAttribute('data-id', work.id);
            card.setAttribute('data-category', work.category);
            card.setAttribute('data-subcategory', work.subcategory);
            
            let previewContent = '';
            if (work.type === 'image') {
                if (work.isExternal || work.fromCloud) {
                    previewContent = `<img src="${work.preview}" alt="${work.title}" loading="lazy" onerror="this.parentElement.innerHTML='<div style=\\'display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-light);\\'><i class=\\'fas fa-image\\' style=\\'font-size:3rem;opacity:0.5;\\'></i><span style=\\'margin-left:10px;\\'>图片加载失败</span></div>'">`;
                } else if (work.missingImage) {
                    previewContent = `<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-light);">
                        <i class="fas fa-image" style="font-size:3rem;opacity:0.5;"></i>
                        <span style="margin-left:10px;">图片已丢失</span>
                    </div>`;
                } else {
                    previewContent = `<img src="${work.preview}" alt="${work.title}" loading="lazy">`;
                }
            } else if (work.type === 'video') {
                previewContent = `<video controls><source src="${work.preview}" type="video/mp4">您的浏览器不支持视频播放</video>`;
            } else if (work.type === 'document') {
                previewContent = `<div class="document-preview"><i class="fas fa-file-pdf"></i><div class="doc-title">${work.preview}</div></div>`;
            }
            
            card.innerHTML = `
                <div class="work-preview">${previewContent}</div>
                <div class="work-info">
                    <span class="work-category" data-id="${work.id}">🏷️ ${subcategoryMap[work.subcategory] || work.subcategory}</span>
                    <input type="text" class="work-title-input" value="${work.title}" placeholder="请输入作品名称">
                    <p class="work-description">${work.description}</p>
                </div>
                <div class="work-meta">
                    <span></span>
                    <span>${categoryMap[work.category]}</span>
                </div>
                <div class="work-controls">
                    <button class="icon-btn" title="编辑"><i class="fas fa-edit"></i></button>
                    <button class="icon-btn delete-btn" title="删除" data-id="${work.id}"><i class="fas fa-trash"></i></button>
                </div>
            `;
            
            card.addEventListener('click', function(e) {
                if (e.target.closest('.work-controls') || e.target.closest('.work-title-input')) return;
                openImagePreview(work);
            });
            
            const deleteBtn = card.querySelector('.delete-btn');
            deleteBtn.addEventListener('click', function() {
                const workId = parseInt(this.getAttribute('data-id'));
                deleteWork(workId);
            });
            
            const categorySpan = card.querySelector('.work-category');
            categorySpan.addEventListener('click', function(e) {
                e.stopPropagation();
                const workId = parseInt(this.getAttribute('data-id'));
                const workItem = worksData.find(w => w.id === workId);
                if (workItem) editSubcategory(workItem);
            });
            
            const titleInput = card.querySelector('.work-title-input');
            titleInput.addEventListener('input', function(e) {
                e.stopPropagation();
                const workId = parseInt(card.getAttribute('data-id'));
                const workItem = worksData.find(w => w.id === workId);
                if (workItem) {
                    workItem.title = this.value;
                    saveToStorage();
                }
            });
            
            titleInput.addEventListener('click', function(e) {
                e.stopPropagation();
            });
            
            const editBtn = card.querySelector('.fa-edit').closest('button');
            editBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                titleInput.focus();
            });
            
            return card;
        }
        
        function openImagePreview(work) {
            if (work.type === 'image') {
                if (work.isExternal || work.fromCloud) {
                    imagePreviewContent.innerHTML = `<img src="${work.preview}" alt="${work.title}">`;
                } else if (work.missingImage) {
                    imagePreviewContent.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;width:600px;height:400px;background:rgba(255,255,255,0.1);border-radius:12px;color:rgba(255,255,255,0.5);"><i class="fas fa-image" style="font-size:4rem;"></i><span style="margin-left:15px;">图片已丢失，请重新上传</span></div>`;
                } else {
                    imagePreviewContent.innerHTML = `<img src="${work.preview}" alt="${work.title}">`;
                }
            } else if (work.type === 'video') {
                imagePreviewContent.innerHTML = `<video controls autoplay><source src="${work.preview}" type="video/mp4">您的浏览器不支持视频播放</video>`;
            } else if (work.type === 'document') {
                imagePreviewContent.innerHTML = `<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;width:500px;padding:60px;background:rgba(255,255,255,0.1);border-radius:12px;color:white;"><i class="fas fa-file-alt" style="font-size:5rem;margin-bottom:20px;"></i><h3 style="font-size:1.5rem;margin-bottom:10px;">${work.preview}</h3><p style="color:rgba(255,255,255,0.7);">文档类型文件无法预览</p></div>`;
            }
            
            previewTitle.textContent = work.title;
            previewCategory.innerHTML = `🏷️ ${subcategoryMap[work.subcategory] || work.subcategory} · ${categoryMap[work.category]}`;
            previewDescription.textContent = work.description;
            
            imagePreviewOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        
        function closeImagePreview() {
            imagePreviewOverlay.classList.remove('active');
            document.body.style.overflow = '';
            const video = imagePreviewContent.querySelector('video');
            if (video) video.pause();
        }
        
        imagePreviewClose.addEventListener('click', closeImagePreview);
        imagePreviewOverlay.addEventListener('click', function(e) {
            if (e.target === imagePreviewOverlay) closeImagePreview();
        });
        
        function editSubcategory(work) {
            const subcategories = categoryToSubcategories[work.category] || Object.keys(subcategoryMap);
            
            const menu = document.createElement('div');
            menu.style.cssText = `position:fixed;background:var(--panel-bg);border-radius:14px;box-shadow:0 10px 40px rgba(0,0,0,0.2);padding:12px 0;z-index:5100;min-width:180px;max-height:320px;overflow-y:auto;`;
            
            subcategories.forEach(subcat => {
                const item = document.createElement('div');
                item.textContent = subcategoryMap[subcat] || subcat;
                item.style.cssText = 'padding:12px 22px;cursor:pointer;transition:background 0.2s;color:var(--text-dark);';
                item.addEventListener('mouseenter', () => item.style.backgroundColor = 'rgba(99, 102, 241, 0.1)');
                item.addEventListener('mouseleave', () => item.style.backgroundColor = 'transparent');
                item.addEventListener('click', () => {
                    work.subcategory = subcat;
                    saveToStorage();
                    renderWorks();
                    menu.remove();
                    showToast('✨ 分类已更新');
                });
                menu.appendChild(item);
            });
            
            const customItem = document.createElement('div');
            customItem.innerHTML = '<i class="fas fa-plus"></i> 自定义分类';
            customItem.style.cssText = 'padding:12px 22px;cursor:pointer;transition:background 0.2s;color:var(--accent-color);border-top:1px solid var(--light-gray);margin-top:8px;';
            customItem.addEventListener('click', () => { menu.remove(); showCustomSubcategoryDialog(work); });
            menu.appendChild(customItem);
            
            const categorySpan = document.querySelector(`.work-category[data-id="${work.id}"]`);
            const rect = categorySpan.getBoundingClientRect();
            menu.style.top = `${rect.bottom + window.scrollY + 8}px`;
            menu.style.left = `${Math.min(rect.left + window.scrollX, window.innerWidth - 220)}px`;
            
            document.body.appendChild(menu);
            
            const closeMenu = (e) => {
                if (!menu.contains(e.target) && e.target !== categorySpan) {
                    menu.remove();
                    document.removeEventListener('click', closeMenu);
                }
            };
            setTimeout(() => document.addEventListener('click', closeMenu), 0);
        }
        
        function showCustomSubcategoryDialog(work) {
            const input = prompt('请输入新的二级分类名称：');
            if (input && input.trim()) {
                const newSubcat = input.trim();
                subcategoryMap[newSubcat] = newSubcat;
                work.subcategory = newSubcat;
                saveToStorage();
                renderWorks();
                showToast('✨ 已创建新分类：' + newSubcat);
            }
        }
        
        function deleteWork(workId) {
            if (isPasswordProtected) {
                showPasswordDialog('删除作品', async () => { await performDelete(workId); });
            } else {
                if (confirm('确定要删除这个作品吗？')) performDelete(workId);
            }
        }
        
        async function performDelete(workId) {
            const card = document.querySelector(`.work-card[data-id="${workId}"]`);
            if (card) {
                card.style.opacity = '0';
                card.style.transform = 'translateY(30px) scale(0.9)';
                
                setTimeout(async () => {
                    const index = worksData.findIndex(w => w.id === workId);
                    if (index !== -1) {
                        const work = worksData[index];
                        
                        // 从云端删除
                        if (work.cloudPath) {
                            await deleteFromCloud(work.cloudPath);
                        }
                        
                        // 删除本地缓存
                        if (imageBlobCache[workId]) {
                            URL.revokeObjectURL(imageBlobCache[workId]);
                            delete imageBlobCache[workId];
                            try { await deleteImageFromIndexedDB(workId); } catch(e) {}
                        }
                        
                        worksData.splice(index, 1);
                    }
                    saveToStorage();
                    renderWorks();
                    updateSystemStatus();
                    showToast('✨ 作品已删除');
                }, 300);
            }
        }
        
        function showPasswordDialog(action, callback) {
            passwordDialogTitle.textContent = `🔐 请输入密码以${action}`;
            passwordInput.value = '';
            passwordError.textContent = '';
            passwordOverlay.classList.add('active');
            
            pendingAction = { action: action, callback: callback };
            passwordInput.focus();
        }
        
        function verifyPassword(inputPassword) {
            return inputPassword === password;
        }
        
        // ============================================
        // 事件监听器
        // ============================================
        
        searchBtn.addEventListener('click', () => {
            searchContainer.classList.toggle('active');
            if (searchContainer.classList.contains('active')) {
                searchInput.focus();
            } else {
                searchInput.value = '';
                searchQuery = '';
                renderWorks();
            }
        });
        
        searchInput.addEventListener('input', (e) => {
            searchQuery = e.target.value;
            renderWorks();
        });
        
        sortSelect.addEventListener('change', (e) => {
            currentSort = e.target.value;
            saveToStorage();
            renderWorks();
        });
        
        themeOptions.forEach(option => {
            option.addEventListener('click', function() {
                const theme = this.dataset.theme;
                themeOptions.forEach(opt => opt.classList.remove('active'));
                this.classList.add('active');
                document.body.className = theme === 'default' ? '' : 'theme-' + theme;
                currentThemeSpan.textContent = themeNames[theme];
                currentThemeSpan.style.background = 'linear-gradient(135deg, var(--primary-color), var(--accent-color))';
                currentThemeSpan.style.webkitBackgroundClip = 'text';
                currentThemeSpan.style.webkitTextFillColor = 'transparent';
                saveToStorage();
                showToast(`🎨 已切换到${themeNames[theme]}主题`);
            });
        });
        
        categoryTags.addEventListener('click', (e) => {
            const tag = e.target.closest('.category-tag');
            if (tag && tag.dataset.category && !tag.classList.contains('add-custom')) {
                filterByCategory(tag.dataset.category);
            }
        });
        
        addCustomCategoryBtn.addEventListener('click', () => {
            customCategoryDialog.classList.add('active');
            customCategoryInput.value = '';
            customCategoryInput.focus();
        });
        
        cancelCustomCategoryBtn.addEventListener('click', () => {
            customCategoryDialog.classList.remove('active');
        });
        
        confirmCustomCategoryBtn.addEventListener('click', () => {
            const name = customCategoryInput.value.trim();
            if (name) {
                const id = 'custom_' + Date.now();
                customCategories.push({ id, name });
                saveToStorage();
                renderCustomCategories();
                customCategoryDialog.classList.remove('active');
                showToast('✨ 分类已添加：' + name);
            } else {
                showToast('请输入分类名称');
            }
        });
        
        uploadOptions.forEach(option => {
            option.addEventListener('click', function() {
                const type = this.getAttribute('data-type');
                
                if (isPasswordProtected) {
                    showPasswordDialog('上传作品', () => { triggerFileInput(type); });
                } else {
                    triggerFileInput(type);
                }
            });
        });
        
        function triggerFileInput(type) {
            if (type === 'image') fileInput.setAttribute('accept', 'image/*');
            else if (type === 'video') fileInput.setAttribute('accept', 'video/*');
            else if (type === 'document') fileInput.setAttribute('accept', '.pdf,.doc,.docx,.txt');
            fileInput.click();
        }
        
        fileInput.addEventListener('change', async function(e) {
            if (e.target.files.length === 0) return;
            
            const file = e.target.files[0];
            const fileType = getFileType(file.type);
            
            const newId = worksData.length > 0 ? Math.max(...worksData.map(w => w.id)) + 1 : 1;
            
            const newWork = {
                id: newId,
                title: file.name.replace(/\.[^/.]+$/, ""),
                category: fileType === 'image' ? 'image' : fileType === 'video' ? 'video' : 'text',
                subcategory: fileType === 'image' ? '摄像' : fileType === 'video' ? '剪辑' : '品牌策划',
                type: fileType,
                description: '新上传的作品',
                preview: '',
                isExternal: false,
                cloudPath: null
            };
            
            try {
                showUploadProgress(0, '准备上传...');
                
                // 保存到本地缓存
                if (fileType === 'image') {
                    await saveImageToIndexedDB(newId, file);
                    imageBlobCache[newId] = URL.createObjectURL(file);
                    newWork.preview = imageBlobCache[newId];
                    newWork.idbBlob = file;
                }
                
                // 上传到云端
                if (isCloudConnected) {
                    const cloudResult = await uploadToCloud(file.name, file, (percent) => {
                        showUploadProgress(percent, `上传中... ${percent}%`);
                    });
                    newWork.cloudPath = cloudResult.path;
                    newWork.preview = cloudResult.url;
                    newWork.fromCloud = true;
                    showToast('☁️ 已上传至云端');
                } else {
                    showToast('⚠️ 云端未连接，仅保存在本地');
                }
                
                worksData.unshift(newWork);
                saveToStorage();
                fileInput.value = '';
                renderWorks();
                updateSystemStatus();
                showToast('✨ 作品上传成功！');
                
            } catch (err) {
                console.error('上传失败:', err);
                showToast('❌ 上传失败：' + (err.message || '请检查网络连接'));
            } finally {
                hideUploadProgress();
            }
        });
        
        function getFileType(mimeType) {
            if (mimeType.startsWith('image/')) return 'image';
            if (mimeType.startsWith('video/')) return 'video';
            return 'document';
        }
        
        settingsBtn.addEventListener('click', () => {
            settingsPanel.classList.add('active');
        });
        
        closeSettings.addEventListener('click', () => {
            settingsPanel.classList.remove('active');
        });
        
        savePasswordBtn.addEventListener('click', () => {
            const currentPassword = currentPasswordInput.value;
            const newPassword = newPasswordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            
            if (currentPassword !== password) {
                showToast('❌ 当前密码错误！');
                return;
            }
            
            if (newPassword.length !== 4 || !/^\d+$/.test(newPassword)) {
                showToast('❌ 新密码必须是4位数字！');
                return;
            }
            
            if (newPassword !== confirmPassword) {
                showToast('❌ 两次输入的密码不一致！');
                return;
            }
            
            password = newPassword;
            saveToStorage();
            
            currentPasswordInput.value = '';
            newPasswordInput.value = '';
            confirmPasswordInput.value = '';
            
            updateSystemStatus();
            showToast('✅ 密码设置已保存！');
        });
        
        passwordProtection.addEventListener('click', function(e) {
            e.preventDefault();
            
            const targetState = !isPasswordProtected;
            const action = targetState ? '启用密码保护' : '取消密码保护';
            
            showPasswordDialog(action, () => {
                isPasswordProtected = targetState;
                passwordProtection.checked = isPasswordProtected;
                saveToStorage();
                updateSystemStatus();
                
                const message = isPasswordProtected ? '🔐 密码保护已启用' : '🔓 密码保护已禁用';
                showToast(message);
            });
        });
        
        cancelPasswordBtn.addEventListener('click', () => {
            passwordOverlay.classList.remove('active');
            pendingAction = null;
        });
        
        confirmPasswordBtnElement.addEventListener('click', () => {
            const inputPassword = passwordInput.value;
            
            if (inputPassword.length !== 4 || !/^\d+$/.test(inputPassword)) {
                passwordError.textContent = '密码必须是4位数字';
                return;
            }
            
            if (!verifyPassword(inputPassword)) {
                passwordError.textContent = '❌ 密码错误，请重试';
                return;
            }
            
            passwordOverlay.classList.remove('active');
            
            if (pendingAction && pendingAction.callback) {
                pendingAction.callback();
            }
            
            pendingAction = null;
        });
        
        passwordInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') confirmPasswordBtnElement.click();
        });
        
        exportDataBtn.addEventListener('click', async () => {
            const exportData = {
                works: [],
                settings: { password: password, isPasswordProtected: isPasswordProtected },
                categories: customCategories,
                exportDate: new Date().toISOString()
            };
            
            for (const work of worksData) {
                if (work.type === 'image' && !work.isExternal && work.idbBlob) {
                    const reader = new FileReader();
                    const base64 = await new Promise((resolve) => {
                        reader.onload = () => resolve(reader.result);
                        reader.readAsDataURL(work.idbBlob);
                    });
                    exportData.works.push({ ...work, blobBase64: base64 });
                } else {
                    exportData.works.push(work);
                }
            }
            
            const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'portfolio_backup.json';
            a.click();
            URL.revokeObjectURL(url);
            
            showToast('📤 数据已导出');
        });
        
        clearDataBtn.addEventListener('click', async () => {
            if (isPasswordProtected) {
                showPasswordDialog('清除所有数据', async () => {
                    if (confirm('⚠️ 确定要清除所有数据吗？此操作不可恢复！')) {
                        try {
                            const transaction = db.transaction([STORE_NAME], 'readwrite');
                            const store = transaction.objectStore(STORE_NAME);
                            store.clear();
                        } catch (e) {}
                        
                        Object.values(imageBlobCache).forEach(url => URL.revokeObjectURL(url));
                        imageBlobCache = {};
                        
                        localStorage.removeItem(STORAGE_KEYS.WORKS);
                        localStorage.removeItem(STORAGE_KEYS.SETTINGS);
                        localStorage.removeItem(STORAGE_KEYS.CATEGORIES);
                        location.reload();
                    }
                });
            } else {
                if (confirm('⚠️ 确定要清除所有数据吗？此操作不可恢复！')) {
                    try {
                        const transaction = db.transaction([STORE_NAME], 'readwrite');
                        const store = transaction.objectStore(STORE_NAME);
                        store.clear();
                    } catch (e) {}
                    
                    Object.values(imageBlobCache).forEach(url => URL.revokeObjectURL(url));
                    imageBlobCache = {};
                    
                    localStorage.removeItem(STORAGE_KEYS.WORKS);
                    localStorage.removeItem(STORAGE_KEYS.SETTINGS);
                    localStorage.removeItem(STORAGE_KEYS.CATEGORIES);
                    location.reload();
                }
            }
        });
        
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                if (imagePreviewOverlay.classList.contains('active')) {
                    closeImagePreview();
                } else if (passwordOverlay.classList.contains('active')) {
                    cancelPasswordBtn.click();
                } else if (settingsPanel.classList.contains('active')) {
                    settingsPanel.classList.remove('active');
                } else if (customCategoryDialog.classList.contains('active')) {
                    customCategoryDialog.classList.remove('active');
                } else if (searchContainer.classList.contains('active')) {
                    searchContainer.classList.remove('active');
                    searchInput.value = '';
                    searchQuery = '';
                    renderWorks();
                } else {
                    filterByCategory('all');
                }
            }
            
            if (e.ctrlKey && e.key === 'f') {
                e.preventDefault();
                searchContainer.classList.add('active');
                searchInput.focus();
            }
        });
        
        passwordOverlay.addEventListener('click', (e) => {
            if (e.target === passwordOverlay) cancelPasswordBtn.click();
        });
        
        customCategoryInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') confirmCustomCategoryBtn.click();
        });
        
        // ============================================
        // 初始化
        // ============================================
        async function init() {
            try {
                // 初始化 IndexedDB
                await initIndexedDB();
                
                // 初始化 Supabase
                await initSupabase();
                
                // 加载数据
                await loadFromStorage();
                renderWorks();
                console.log('✨ 作品集初始化完成');
                console.log('☁️ 云端状态:', isCloudConnected ? '已连接' : '未连接（本地模式）');
            } catch (error) {
                console.error('初始化失败:', error);
                showToast('❌ 初始化失败，请刷新页面重试');
            }
        }
        
        init();
    </script>
</body>
</html>
