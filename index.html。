        .custom-category-title {
            font-size: 1.4rem;
            color: var(--primary-color);
            margin-bottom: 25px;
            text-align: center;
            font-weight: 700;
        }
        
        .custom-category-input {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            font-size: 1.05rem;
