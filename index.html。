<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>个人创意作品集</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Supabase SDK -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif;
        }
        
        /* ============================================
           主题变量定义
           ============================================ */
        
        :root {
            --primary-color: #6366f1;
            --secondary-color: #f8fafc;
            --accent-color: #8b5cf6;
            --light-gray: #e2e8f0;
            --dark-gray: #64748b;
            --text-dark: #1e293b;
            --text-light: #64748b;
            --card-shadow: 0 4px 20px rgba(99, 102, 241, 0.08);
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --card-bg: #ffffff;
            --header-bg: transparent;
            --panel-bg: #ffffff;
            --input-bg: #ffffff;
            --overlay-bg: rgba(0, 0, 0, 0.5);
            --gradient-bg: linear-gradient(135deg, #f8fafc 0%, #e0e7ff 50%, #fce7f3 100%);
            --card-glow: none;
            --gold-accent: transparent;
            --border-radius: 16px;
        }
        
        body.theme-dark {
            --primary-color: #818cf8;
            --secondary-color: #0f172a;
            --accent-color: #a78bfa;
            --light-gray: #1e293b;
            --dark-gray: #94a3b8;
            --text-dark: #f1f5f9;
            --text-light: #94a3b8;
            --card-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
            --card-bg: rgba(30, 41, 59, 0.8);
            --header-bg: transparent;
            --panel-bg: #1e293b;
            --input-bg: #0f172a;
            --overlay-bg: rgba(0, 0, 0, 0.8);
            --gradient-bg: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
            --card-glow: 0 0 30px rgba(139, 92, 246, 0.3);
            --gold-accent: #c4b5fd;
            --border-radius: 16px;
        }
        
        body.theme-grand {
            --primary-color: #1a1a2e;
            --secondary-color: #16213e;
            --accent-color: #e94560;
            --light-gray: #2a2a4a;
            --dark-gray: #8a8aaa;
            --text-dark: #ffffff;
            --text-light: #b0b0d0;
            --card-shadow: 0 8px 32px rgba(233, 69, 96, 0.2);
            --card-bg: rgba(26, 26, 46, 0.9);
            --header-bg: transparent;
            --panel-bg: #1a1a2e;
            --input-bg: #16213e;
            --overlay-bg: rgba(0, 0, 0, 0.85);
            --gradient-bg: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            --card-glow: 0 0 20px rgba(233, 69, 96, 0.3);
            --gold-accent: #ffd700;
            --border-radius: 12px;
        }
        
        body.theme-fashion {
            --primary-color: #2d2d2d;
            --secondary-color: #ffffff;
            --accent-color: #ff6b6b;
            --light-gray: #f0f0f0;
            --dark-gray: #666666;
            --text-dark: #333333;
            --text-light: #888888;
            --card-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            --card-bg: #ffffff;
            --header-bg: transparent;
            --panel-bg: #ffffff;
            --input-bg: #f8f8f8;
            --overlay-bg: rgba(0, 0, 0, 0.6);
            --gradient-bg: none;
            --card-glow: none;
            --gold-accent: transparent;
            --border-radius: 20px;
        }
        
        body.theme-fresh {
            --primary-color: #059669;
            --secondary-color: #ecfdf5;
            --accent-color: #10b981;
            --light-gray: #d1fae5;
            --dark-gray: #047857;
            --text-dark: #064e3b;
            --text-light: #059669;
            --card-shadow: 0 4px 20px rgba(16, 185, 129, 0.15);
            --card-bg: #ffffff;
            --header-bg: transparent;
            --panel-bg: #ffffff;
            --input-bg: #ffffff;
            --overlay-bg: rgba(0, 0, 0, 0.5);
            --gradient-bg: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 50%, #a7f3d0 100%);
            --card-glow: 0 0 20px rgba(16, 185, 129, 0.2);
            --gold-accent: transparent;
            --border-radius: 16px;
        }
        
        body.theme-retro {
            --primary-color: #92400e;
            --secondary-color: #fef3c7;
            --accent-color: #d97706;
            --light-gray: #fde68a;
            --dark-gray: #b45309;
            --text-dark: #451a03;
            --text-light: #92400e;
            --card-shadow: 0 4px 20px rgba(146, 64, 14, 0.15);
            --card-bg: #fffbeb;
            --header-bg: transparent;
            --panel-bg: #fffbeb;
            --input-bg: #fef3c7;
            --overlay-bg: rgba(69, 26, 3, 0.6);
            --gradient-bg: linear-gradient(135deg, #fef3c7 0%, #fde68a 50%, #fcd34d 100%);
            --card-glow: none;
            --gold-accent: #f59e0b;
            --border-radius: 12px;
        }
        
        body.theme-sunset {
            --primary-color: #dc2626;
            --secondary-color: #fef2f2;
            --accent-color: #f97316;
            --light-gray: #fed7aa;
            --dark-gray: #ea580c;
            --text-dark: #7c2d12;
            --text-light: #dc2626;
            --card-shadow: 0 4px 20px rgba(249, 115, 22, 0.2);
            --card-bg: #ffffff;
            --header-bg: transparent;
            --panel-bg: #ffffff;
            --input-bg: #fef2f2;
            --overlay-bg: rgba(124, 45, 18, 0.6);
            --gradient-bg: linear-gradient(135deg, #fef2f2 0%, #fecaca 50%, #fca5a5 100%);
            --card-glow: 0 0 25px rgba(249, 115, 22, 0.3);
            --gold-accent: #fbbf24;
            --border-radius: 16px;
        }
        
        body {
            background: var(--gradient-bg);
            background-attachment: fixed;
            color: var(--text-dark);
            line-height: 1.6;
            min-height: 100vh;
            padding: 20px;
            max-width: 1500px;
            margin: 0 auto;
            transition: background 0.5s ease, color 0.5s ease;
        }
        
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(139, 92, 246, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 50% 50%, rgba(16, 185, 129, 0.05) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
            animation: bgFloat 20s ease-in-out infinite;
        }
        
        body.theme-dark::before {
            background: 
                radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(99, 102, 241, 0.1) 0%, transparent 40%);
        }
        
        @keyframes bgFloat {
            0%, 100% { transform: scale(1) rotate(0deg); }
            50% { transform: scale(1.05) rotate(1deg); }
        }
        
        body > * {
            position: relative;
            z-index: 1;
        }
        
        .header {
            text-align: center;
            padding: 60px 20px 40px;
            margin-bottom: 30px;
            animation: fadeInDown 0.8s ease-out;
            position: relative;
            background: var(--header-bg);
        }
        
        .site-title {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 3px;
            margin-bottom: 15px;
            transition: all 0.5s ease;
            position: relative;
            display: inline-block;
        }
        
        .site-title::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
            border-radius: 2px;
        }
        
        .site-subtitle {
            font-size: 1.3rem;
            color: var(--dark-gray);
            font-weight: 400;
            max-width: 600px;
            margin: 20px auto 0;
            opacity: 0.9;
        }
        
        .header-toolbar {
            position: absolute;
            top: 30px;
            right: 30px;
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        .search-container {
            position: relative;
            display: flex;
            align-items: center;
        }
        
        .search-input {
            width: 0;
            padding: 12px 0;
            border: none;
            background: transparent;
            font-size: 1rem;
            color: var(--text-dark);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0;
        }
        
        .search-container.active .search-input {
            width: 240px;
            padding: 12px 20px;
            border: 2px solid var(--light-gray);
            border-radius: 30px;
            background: var(--input-bg);
            opacity: 1;
        }
        
        .search-input:focus {
            outline: none;
            border-color: var(--accent-color);
            box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
        }
        
        .search-btn, .settings-btn {
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            border: none;
            color: white;
            font-size: 1rem;
            cursor: pointer;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }
        
        .search-btn:hover, .settings-btn:hover {
            transform: scale(1.1) rotate(15deg);
            box-shadow: 0 6px 25px rgba(99, 102, 241, 0.4);
        }
        
        .settings-btn:hover {
            transform: scale(1.1) rotate(90deg);
        }
        
        .settings-panel {
            position: fixed;
            top: 0;
            right: -450px;
            width: 420px;
            height: 100vh;
            background-color: var(--panel-bg);
            box-shadow: -10px 0 40px rgba(0, 0, 0, 0.15);
            padding: 40px 30px;
            z-index: 1000;
            transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.5s ease;
            overflow-y: auto;
            backdrop-filter: blur(10px);
        }
        
        .settings-panel.active {
            right: 0;
        }
        
        .settings-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 35px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--light-gray);
        }
        
        .settings-title {
            font-size: 1.6rem;
            color: var(--primary-color);
            font-weight: 700;
        }
        
        .close-settings {
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            border: none;
            font-size: 1.2rem;
            color: white;
            cursor: pointer;
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: var(--transition);
        }
        
        .close-settings:hover {
            transform: rotate(90deg) scale(1.1);
        }
        
        .setting-group {
            margin-bottom: 30px;
        }
        
        .setting-label {
            display: block;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-dark);
            font-size: 1.05rem;
        }
        
        .setting-input {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            font-size: 1rem;
            background: var(--input-bg);
            color: var(--text-dark);
            transition: var(--transition);
        }
        
        .setting-input:focus {
            outline: none;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
        }
        
        .theme-selector {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-top: 12px;
        }
        
        .theme-option {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 18px 12px;
            border: 3px solid var(--light-gray);
            border-radius: 14px;
            cursor: pointer;
            transition: var(--transition);
            background: var(--card-bg);
            position: relative;
            overflow: hidden;
        }
        
        .theme-option::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s ease;
        }
        
        .theme-option:hover::before {
            left: 100%;
        }
        
        .theme-option:hover {
            border-color: var(--accent-color);
            transform: translateY(-4px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        }
        
        .theme-option.active {
            border-color: var(--accent-color);
            box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2), 0 8px 25px rgba(0, 0, 0, 0.12);
        }
        
        .theme-preview {
            display: flex;
            gap: 5px;
            margin-bottom: 10px;
        }
        
        .theme-preview-color {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid rgba(0,0,0,0.1);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        .theme-name {
            font-size: 0.9rem;
            color: var(--text-dark);
            font-weight: 600;
        }
        
        .checkbox-group {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: var(--accent-color);
        }
        
        .checkbox-group label {
            cursor: pointer;
            color: var(--text-dark);
        }
        
        .setting-btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 14px;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            color: white;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
            margin-top: 15px;
        }
        
        .setting-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
        }
        
        .setting-btn.secondary {
            background: linear-gradient(135deg, var(--light-gray), #cbd5e1);
            color: var(--text-dark);
            box-shadow: none;
        }
        
        .setting-btn.secondary:hover {
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }
        
        .setting-btn.danger {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
        }
        
        .setting-btn.danger:hover {
            box-shadow: 0 8px 25px rgba(239, 68, 68, 0.4);
        }
        
        /* 密码输入遮罩 */
        .password-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--overlay-bg);
            z-index: 6000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
            backdrop-filter: blur(5px);
        }
        
        .password-overlay.active {
            opacity: 1;
            visibility: visible;
        }
        
        .password-dialog {
            background: var(--panel-bg);
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            text-align: center;
            animation: modalIn 0.3s ease;
            width: 90%;
            max-width: 380px;
        }
        
        @keyframes modalIn {
            from { transform: scale(0.9); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        
        .password-title {
            font-size: 1.5rem;
            color: var(--primary-color);
            margin-bottom: 25px;
            font-weight: 700;
        }
        
        .password-input-group {
            margin-bottom: 25px;
        }
        
        .password-input {
            width: 100%;
            padding: 18px;
            border: 3px solid var(--light-gray);
            border-radius: 14px;
            font-size: 1.5rem;
            text-align: center;
            letter-spacing: 8px;
            background: var(--input-bg);
            color: var(--text-dark);
            transition: var(--transition);
        }
        
        .password-input:focus {
            outline: none;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
        }
        
        .password-error {
            color: #ef4444;
            font-size: 0.9rem;
            margin-top: 10px;
            min-height: 20px;
        }
        
        .password-actions {
            display: flex;
            gap: 15px;
        }
        
        .password-btn {
            flex: 1;
            padding: 14px;
            border: none;
            border-radius: 12px;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }
        
        .password-btn.cancel {
            background: var(--light-gray);
            color: var(--text-dark);
        }
        
        .password-btn.confirm {
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            color: white;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }
        
        .password-btn:hover {
            transform: translateY(-2px);
        }
        
        /* 导航 */
        .nav-container {
            margin-bottom: 35px;
            animation: fadeInUp 0.6s ease-out 0.2s both;
        }
        
        .nav-primary {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 20px;
        }
        
        .nav-btn {
            padding: 12px 28px;
            border: 2px solid var(--light-gray);
            border-radius: 30px;
            background: var(--card-bg);
            color: var(--text-dark);
            font-size: 1.05rem;
            cursor: pointer;
            transition: var(--transition);
            font-weight: 500;
        }
        
        .nav-btn.active {
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            color: white;
            border-color: transparent;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }
        
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .category-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .category-tag {
            padding: 8px 18px;
            border: 2px solid var(--light-gray);
            border-radius: 20px;
            background: var(--card-bg);
            color: var(--text-dark);
            font-size: 0.95rem;
            cursor: pointer;
            transition: var(--transition);
            font-weight: 500;
        }
        
        .category-tag:hover, .category-tag.active {
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            color: white;
            border-color: transparent;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }
        
        .category-tag.add-custom {
            border-style: dashed;
            color: var(--accent-color);
        }
        
        .category-tag.add-custom:hover {
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            color: white;
            border-style: solid;
        }
        
        .sort-container {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .sort-label {
            color: var(--text-dark);
            font-weight: 500;
        }
        
        .sort-select {
            padding: 10px 18px;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            background: var(--input-bg);
            color: var(--text-dark);
            font-size: 0.95rem;
            cursor: pointer;
            transition: var(--transition);
        }
        
        .sort-select:focus {
            outline: none;
            border-color: var(--accent-color);
        }
        
        .content-area {
            padding: 0 10px 60px;
            animation: fadeInUp 0.6s ease-out 0.4s both;
        }
        
        .works-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 35px;
        }
        
        .work-card {
            background-color: var(--card-bg);
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--card-shadow);
            transition: var(--transition);
            animation: fadeInUp 0.6s ease-out;
            animation-fill-mode: both;
            opacity: 0;
            position: relative;
            cursor: pointer;
        }
        
        .work-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-color), var(--accent-color), var(--primary-color));
            background-size: 200% 100%;
            animation: gradientMove 3s linear infinite;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        @keyframes gradientMove {
            0% { background-position: 0% 0%; }
            100% { background-position: 200% 0%; }
        }
        
        .work-card:hover::before {
            opacity: 1;
        }
        
        body.theme-grand .work-card {
            box-shadow: var(--card-glow), var(--card-shadow);
            border: 1px solid rgba(233, 69, 96, 0.2);
        }
        
        .work-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 20px 40px rgba(99, 102, 241, 0.15), 0 0 0 1px rgba(99, 102, 241, 0.1);
        }
        
        body.theme-grand .work-card:hover {
            box-shadow: 0 0 40px rgba(233, 69, 96, 0.4), 0 20px 40px rgba(0, 0, 0, 0.2);
        }
        
        body.theme-dark .work-card:hover {
            box-shadow: 0 0 40px rgba(139, 92, 246, 0.3), 0 20px 40px rgba(0, 0, 0, 0.3);
        }
        
        .work-preview {
            height: 220px;
            position: relative;
            overflow: hidden;
