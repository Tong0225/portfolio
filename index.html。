            transition: var(--transition);
        }
        
        .custom-category-input:focus {
            outline: none;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
        }
        
        .custom-category-actions {
            display: flex;
            gap: 15px;
        }
        
        .custom-category-btn {
            flex: 1;
            padding: 14px;
            border: none;
            border-radius: 12px;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }
        
        .custom-category-btn.cancel {
            background: var(--light-gray);
            color: var(--text-dark);
        }
        
        .custom-category-btn.confirm {
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            color: white;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }
        
        .custom-category-btn.confirm:hover {
            box-shadow: 0 6px 25px rgba(99, 102, 241, 0.4);
        }
        
        .image-preview-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.92);
            z-index: 5000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }
        
        .image-preview-overlay.active {
            opacity: 1;
            visibility: visible;
        }
        
        .image-preview-container {
            position: relative;
            max-width: 92vw;
            max-height: 88vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            transform: scale(0.85);
            transition: transform 0.3s ease;
        }
        
        .image-preview-overlay.active .image-preview-container {
            transform: scale(1);
        }
        
        .image-preview-close {
            position: absolute;
            top: -55px;
            right: 0;
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: white;
            font-size: 1.5rem;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .image-preview-close:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: rotate(90deg);
        }
        
        .image-preview-content {
            max-width: 100%;
            max-height: 70vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .image-preview-content img, .image-preview-content video {
            max-width: 100%;
            max-height: 70vh;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }
        
        .image-preview-info {
            text-align: center;
            margin-top: 25px;
            max-width: 700px;
        }
        
        .image-preview-title {
            font-size: 1.8rem;
            color: white;
            margin-bottom: 12px;
            font-weight: 700;
        }
        
        .image-preview-category {
            display: inline-block;
            background: rgba(255, 255, 255, 0.15);
            color: white;
            padding: 6px 18px;
            border-radius: 20px;
            font-size: 0.95rem;
            margin-bottom: 15px;
        }
        
        .image-preview-description {
            color: rgba(255, 255, 255, 0.8);
            font-size: 1.1rem;
            line-height: 1.7;
        }
        
        .image-preview-hint {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.9rem;
        }
        
        .image-preview-hint kbd {
            background: rgba(255, 255, 255, 0.15);
            padding: 4px 10px;
            border-radius: 6px;
            font-family: inherit;
        }
        
        /* 云端状态指示器 */
        .cloud-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(16, 185, 129, 0.1));
            border-radius: 20px;
            font-size: 0.85rem;
            color: #10b981;
            margin-left: 10px;
        }
        
        .cloud-status.syncing {
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(245, 158, 11, 0.1));
            color: #f59e0b;
        }
        
        .cloud-status .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
        
        /* 上传进度条 */
        .upload-progress {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--panel-bg);
            padding: 20px 35px;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            z-index: 4000;
            display: none;
            align-items: center;
            gap: 15px;
        }
        
        .upload-progress.active {
            display: flex;
        }
        
        .upload-progress-bar {
            width: 200px;
            height: 8px;
            background: var(--light-gray);
            border-radius: 4px;
            overflow: hidden;
        }
        
        .upload-progress-fill {
            height: 100%;
            background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
            border-radius: 4px;
            transition: width 0.3s ease;
            width: 0%;
        }
        
        .upload-progress-text {
            color: var(--text-dark);
            font-weight: 500;
            min-width: 100px;
        }
        
        /* 响应式 */
        @media (max-width: 1024px) {
            .site-title {
                font-size: 2.8rem;
            }
            
            .works-grid {
                grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
                gap: 25px;
            }
        }
        
        @media (max-width: 768px) {
            .site-title {
                font-size: 2.4rem;
            }
            
            .site-subtitle {
                font-size: 1.1rem;
            }
            
            .works-grid {
                grid-template-columns: 1fr;
                gap: 25px;
            }
            
            .nav-btn {
                padding: 10px 18px;
                font-size: 1rem;
            }
            
            .upload-options {
                grid-template-columns: 1fr;
            }
            
            .settings-panel {
                width: 100%;
                right: -100%;
            }
            
            .header-toolbar {
                right: 15px;
                top: 20px;
            }
            
            .search-container.active .search-input {
                width: 180px;
            }
            
            .theme-selector {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .upload-section {
                padding: 25px;
            }
        }
        
        @media (max-width: 480px) {
            body {
                padding: 12px;
            }
            
            .works-grid {
                grid-template-columns: 1fr;
            }
            
            .header {
                padding: 30px 10px 20px;
            }
            
            .toolbar {
                flex-direction: column;
                gap: 15px;
            }
            
            .site-title {
                font-size: 2rem;
            }
            
            .theme-selector {
                grid-template-columns: 1fr 1fr;
            }
        }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes fadeInDown {
